    -----END CERTIFICATE-----
  '';
in
{
  # Android Emulator needs host KVM access. The work host already gets this via
  # virt-manager, but keep it here as part of the SIGA Android emulator feature.
  users.users.luiz.extraGroups = [ "kvm" ];

  services.dnsmasq = {
    enable = true;
    settings = {
      listen-address = [ "127.0.0.1" ];
      bind-interfaces = true;
      no-hosts = true;
      no-resolv = true;
      server = [
        "1.1.1.1"
        "8.8.8.8"
      ];
      address = [
        "/roi.local/10.0.2.2"
        "/siga-webshop.local/10.0.2.2"
      ];
    };
  };

  # NixOS Firefox uses the system p11-kit trust source generated from
  # security.pki, so this also fixes browser trust for the local Webshop.
  security.pki.certificates = [ webshopCaddyRoot ];

  environment.etc."android-siga/caddy-local-root.crt" = {
    text = webshopCaddyRoot;
    mode = "0644";
  };
}
