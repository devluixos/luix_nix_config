  # data volume. Never add Caddy's private key to this repository.
  webshopCaddyRoot = ''
    -----BEGIN CERTIFICATE-----
    MIIBpDCCAUqgAwIBAgIRAPVuF6M89GE57woq7xhHhMkwCgYIKoZIzj0EAwIwMDEu
    MCwGA1UEAxMlQ2FkZHkgTG9jYWwgQXV0aG9yaXR5IC0gMjAyNiBFQ0MgUm9vdDAe
    Fw0yNjA3MTQwNjQxNTVaFw0zNjA1MjIwNjQxNTVaMDAxLjAsBgNVBAMTJUNhZGR5
    IExvY2FsIEF1dGhvcml0eSAtIDIwMjYgRUNDIFJvb3QwWTATBgcqhkjOPQIBBggq
    hkjOPQMBBwNCAAQ7wye1ZybZhoPmrmm9Qx2yLu61UCrd57VHNySI7v47Oztn4/0E
    k35iDOxwVGDz7utPocfT8wGF6XIAzAeGy0wso0UwQzAOBgNVHQ8BAf8EBAMCAQYw
    EgYDVR0TAQH/BAgwBgEB/wIBATAdBgNVHQ4EFgQUk/UeMo7D6NbDFM2I0GvtxCnB
    a8owCgYIKoZIzj0EAwIDSAAwRQIhAM3qT32aS1a+3i6P1EUX2vOhfoh8+mxbWgWf
